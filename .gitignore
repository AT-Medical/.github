# AT Medical .github – .gitignore
# This is a governance and configuration repository with no compiled artifacts.
# The following patterns are excluded as a precautionary baseline.

# Environment files (must never be committed)
.env
.env.local
.env.development
.env.staging
.env.production
.env.test

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Editor and IDE artifacts
.vscode/
.idea/
*.swp
*.swo
*~

# Node.js (if tooling is added)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Logs
*.log
logs/
